{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["chapters"],
  "additionalProperties": false,
  "properties": {
    "chapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "display_order", "title", "status"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^ch_[a-z0-9_]+$" },
          "display_order": { "type": "integer", "minimum": 1 },
          "title": { "type": "string" },
          "status": { "enum": ["planned", "drafted", "reviewed", "revised", "archived"] },
          "manuscript_path": { "$ref": "#/$defs/relativePath" },
          "summary": { "type": "string" },
          "scenes": {
            "type": "array",
            "items": { "type": "string", "pattern": "^sc_[a-z0-9_]+$" }
          },
          "links": { "type": "object" }
        }
      }
    }
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "^(?:/|[A-Za-z]:|.*\\.\\..*)" }
    }
  }
}
